# Setup order:
# npm run db:import      # optional: import NGO.sql
# npm run db:setup       # API grants + auth RPCs
# npm run db:migrate     # schema extensions (blog, applications, etc.)
# npm run db:migrate-auth # password reset + resend verification RPCs
# npm run db:seed-demo   # demo users + homepage stats data
# npm run db:seed-homepage # homepage analytics demo listings only
# npm run db:setup-storage # public "uploads" bucket + storage policies
#
# Cron (optional): npm run email:process && npm run alerts:weekly
