# Direct PostgreSQL (IPv6 only — often fails on home/office Wi‑Fi with "nodename nor servname provided")
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Recommended for npm run db:* scripts — Session pooler (IPv4 compatible)
# Supabase Dashboard → Project Settings → Database → Connection string → Session pooler → URI
DATABASE_POOLER_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# Fallback if you only set one variable (scripts prefer DATABASE_POOLER_URL)
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase API (safe for Vite frontend)
VITE_SUPABASE_URL=https://pnkqqggcwhhzzrjubctt.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# App URL (used in verification emails)
APP_BASE_URL=http://localhost:5173

# Email (Resend — server scripts only, never expose in Vite)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=notifications@developmentwala.org

# Stripe (server scripts only)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Demo logins (run: npm run db:seed-demo)
# Candidate: demo@developmentwala.org / DemoPass123
# Employer:  employer@developmentwala.org / DemoPass123
# Admin:     admin@developmentwala.org / DemoPass123

# Setup order:
# npm run db:import      # optional: import NGO.sql
# npm run db:setup       # API grants + auth RPCs
# npm run db:migrate     # schema extensions (blog, applications, etc.)
# npm run db:migrate-auth # password reset + resend verification RPCs
# npm run db:seed-demo   # demo users + homepage stats data
# npm run db:seed-homepage # homepage analytics demo listings only
# npm run db:setup-storage # public "uploads" bucket + storage policies
#
# Cron (optional): npm run email:process && npm run alerts:weekly
